{
  "name": "notebooklm-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web GUI for notebooklm-client — bring-your-own-session web wrapper",
  "scripts": {
    "prelink": "node scripts/link-lib.mjs",
    "link:lib": "node scripts/link-lib.mjs",
    "dev": "npm run link:lib && concurrently -n client,server -c cyan,magenta --kill-others-on-fail \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "node scripts/wait-for-port.mjs 7860 127.0.0.1 60000 && vite",
    "dev:server": "node --watch --import tsx server/index.ts",
    "build": "npm run link:lib && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@eigenpal/docx-editor-react": "^1.3.3",
    "dompurify": "^3.4.8",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "fast-formula-parser": "1.0.19",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "marked": "^14.0.0",
    "mermaid": "^11.15.0",
    "multer": "^1.4.5-lts.1",
    "notebooklm-client": "*",
    "oci-aispeech": "^2.131.0",
    "oci-common": "^2.131.0",
    "oci-generativeaiinference": "^2.131.0",
    "oci-objectstorage": "^2.131.0",
    "oracledb": "^6.10.0",
    "pdf-parse": "^1.1.4",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.8",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.9",
    "react-data-grid": "7.0.0-beta.47",
    "react-spreadsheet": "^0.10.1",
    "recharts": "^3.8.1",
    "ulid": "^2.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/katex": "^0.16.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/oracledb": "^6.10.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
