# ─────────────────────────────────────────────────────────────────────────────
# Research corpus configuration (Oracle Autonomous DB + OCI Object Storage + OCI GenAI)
#
# Copy to `.env` (gitignored) and fill in real values. If any are missing,
# the corpus subsystem is disabled and the rest of the webapp still works.
# ─────────────────────────────────────────────────────────────────────────────

# OCI fundamentals
OCI_CONFIG_FILE=C:/Users/mike_zhang/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=ap-tokyo-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..xxxx

# Object Storage
OCI_NAMESPACE=xxxxxxxxxxxx
OCI_BUCKET=nblm-corpus

# Generative AI (embeddings)
OCI_GENAI_MODEL=cohere.embed-multilingual-v3.0
# Optional: override for GenAI region if your home region doesn't host it.
# Tokyo (ap-tokyo-1) does NOT offer GenAI; cross-region to Osaka.
# https://docs.oracle.com/en-us/iaas/Content/generative-ai/regions.htm
OCI_GENAI_REGION=ap-osaka-1
# Optional: chat model for retrieval-augmented chat (M6 / "Chat over corpus").
# Leave unset to disable the /corpus/chat page; the rest of the corpus
# subsystem (search, library, upload, auto-ingest) keeps working either way.
# Recommended:
#   cohere.command-r-plus-08-2024  - best quality, slower
#   cohere.command-r-08-2024       - faster, still very capable
OCI_GENAI_CHAT_MODEL=cohere.command-r-plus-08-2024

# ── Embedding provider ─────────────────────────────────────────────────
# Controls where text embeddings are generated.
#   'oci'      — OCI GenAI REST API (cohere.embed-multilingual-v3.0) — billed per token
#   'database' — in-database ONNX model via VECTOR_EMBEDDING() SQL — free!
#   'gemini'   — Google Gemini text-embedding-004 — free!
# Default: 'oci' (backward-compatible).
EMBEDDING_PROVIDER=oci
# GEMINI_EMBED_MODEL=text-embedding-004
# Name of the ONNX model loaded via DBMS_VECTOR.LOAD_ONNX_MODEL_CLOUD.
# Only needed when EMBEDDING_PROVIDER=database.
#DB_EMBED_MODEL=BGE_M3_MODEL

# ── Chat provider ──────────────────────────────────────────────────────
# Controls where RAG chat runs. Auto-detected when not set explicitly:
#   If GEMINI_API_KEY is present → 'gemini'
#   Else if OCI_GENAI_CHAT_MODEL is set → 'oci'
#   Otherwise → 'disabled' (search/ingest still work, just no chat)
# Explicit override: CHAT_PROVIDER=gemini | oci | disabled
#CHAT_PROVIDER=gemini
# Google Gemini API key. Free tier: 15 RPM for gemini-2.0-flash.
# Get one at https://aistudio.google.com/apikey
#GEMINI_API_KEY=AIza...
# Gemini model. Default: gemini-2.0-flash (free). Others: gemini-2.5-flash, gemini-1.5-pro
#GEMINI_MODEL=gemini-2.0-flash

# Oracle Autonomous Database (mTLS via wallet, Thin mode — no Instant Client needed)
ORACLE_USER=CORPUS
ORACLE_PASSWORD=replace-with-strong-password
ORACLE_CONNECT_STRING=nblmcorpus_high
ORACLE_WALLET_DIR=C:/Users/mike_zhang/.oci/wallets/nblm-corpus
ORACLE_WALLET_PASSWORD=replace-with-wallet-password

